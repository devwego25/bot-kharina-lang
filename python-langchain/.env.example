# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Redis (use internal Docker network or external)
REDIS_URL=redis://kharina-bot_redis:6379

# MCP - Cardapio (internal network)
MCP_CARDAPIO_URL=http://cardapio_app:3000/mcp
MCP_CARDAPIO_TOKEN=your_token_here

# MCP - Reservas (external - via WARP)
MCP_RESERVAS_URL=https://mcp.reservas.wegosb.com.br/mcp
MCP_RESERVAS_TOKEN=your_token_here

# App Settings
DEBUG=false
LOG_LEVEL=INFO
